# Baba Code Configuration
# Copy this file to .env and customize for your setup

# ===========================================
# Primary AI Provider Selection
# ===========================================
# Options: jan, ollama, lm_studio, openai
BABA_PRIMARY_PROVIDER=jan

# ===========================================
# Jan AI Configuration
# ===========================================
# Jan runs locally at localhost:1337 by default
# Download: https://jan.ai/
JAN_BASE_URL=http://localhost:1337/v1
JAN_MODEL=local-model
JAN_API_KEY=not-needed

# ===========================================
# Ollama Configuration
# ===========================================
# Ollama runs locally at localhost:11434 by default
# Download: https://ollama.ai/
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=llama3.2
OLLAMA_API_KEY=not-needed

# ===========================================
# LM Studio Configuration
# ===========================================
# LM Studio runs locally at localhost:1234 by default
# Download: https://lmstudio.ai/
LM_STUDIO_BASE_URL=http://localhost:1234/v1
LM_STUDIO_MODEL=local-model
LM_STUDIO_API_KEY=not-needed

# ===========================================
# OpenAI Configuration (Cloud Fallback)
# ===========================================
# Uncomment if you want to use OpenAI as primary or fallback
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-3.5-turbo
# OPENAI_API_KEY=your-api-key-here

# ===========================================
# Baba Code Runtime Settings
# ===========================================
BABA_MAX_TOKENS=4096
BABA_TEMPERATURE=0.7
BABA_STREAM=true
BABA_DEBUG=false

# ===========================================
# Baba Home Directory
# ===========================================
# BABA_HOME=~/.baba
